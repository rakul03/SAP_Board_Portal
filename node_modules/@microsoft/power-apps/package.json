{
  "name": "@microsoft/power-apps",
  "version": "1.1.1",
  "type": "module",
  "description": "Power Apps SDK",
  "license": "See license in LICENSE file",
  "exports": {
    "./app": {
      "types": "./dist/app/index.d.ts",
      "default": "./dist/app/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "default": "./dist/data/index.js"
    },
    "./data/executors": {
      "types": "./dist/data/executors/index.d.ts",
      "default": "./dist/data/executors/index.js"
    },
    "./data/metadata/dataverse": {
      "types": "./dist/data/metadata/dataverse/index.d.ts",
      "default": "./dist/data/metadata/dataverse/index.js"
    },
    "./internal/data": {
      "types": "./dist/internal/data/index.d.ts",
      "default": "./dist/internal/data/index.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "default": "./dist/telemetry/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.json --watch",
    "check-types": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "bun test src/",
    "clean": "bun ../../scripts/clean.ts dist .turbo tsconfig.tsbuildinfo tsconfig.build.tsbuildinfo"
  },
  "dependencies": {
    "@microsoft/power-apps-cli": "0.10.0"
  },
  "devDependencies": {
    "@repo/repo-config": "0.0.0",
    "@types/bun": "1.3.9",
    "typescript": "5.9.3"
  }
}
